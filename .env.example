# Copy to .env and adjust paths for your machine.
# cp .env.example .env

# Where OpenG2P product repos are cloned (sibling to this repo by default)
OPENG2P_WORKSPACE=../openg2p-workspace

# Path to Odoo 17 source (cloned by `make clone` unless already present)
ODOO_PATH=../openg2p-workspace/odoo17

# Shared infrastructure (docker compose defaults)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SUPERUSER=postgres
POSTGRES_PASSWORD=postgres

REDIS_HOST=localhost
REDIS_PORT=6379

MINIO_ENDPOINT=localhost:9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=secret

KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Application ports (native/hybrid mode)
PBMS_HTTP_PORT=8069

# Registry Gen2: Farmer Registry
FARMER_REGISTRY_STAFF_API_PORT=8001
FARMER_REGISTRY_UI_PORT=3000
FARMER_REGISTRY_UI_PATH=../openg2p-workspace/openg2p-registry-gen2-staff-portal-ui

# Registry Gen2: National Social Registry
NSR_REGISTRY_STAFF_API_PORT=8011
NSR_REGISTRY_UI_PORT=3010
NSR_REGISTRY_UI_PATH=../openg2p-workspace/openg2p-registry-gen2-staff-portal-ui

# Registry seed options
# LOAD_SAMPLE_DATA=false
# LOAD_IMAGES=false
# LOAD_TEMPLATES=false
# OPENG2P_DATA_DIR=../openg2p-workspace/openg2p-data

G2P_BRIDGE_API_PORT=8002
G2P_BRIDGE_EXAMPLE_BANK_PORT=8003
SPAR_MAPPER_API_PORT=8004
SPAR_BENE_API_PORT=8005

# Git branch/tag pins (override versions.yaml if needed)
PBMS_REF=develop
REGISTRY_REF=develop
FARMER_REGISTRY_REF=develop
NSR_REF=develop
G2P_BRIDGE_REF=develop
SPAR_REF=develop
ODOO_REF=17.0
