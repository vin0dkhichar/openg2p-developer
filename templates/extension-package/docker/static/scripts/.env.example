# Docker Hub credentials — DO NOT COMMIT THIS FILE
# Copy this file to build/.env and fill in your values.
# build/.env is already listed in .gitignore.

# Required when using --push / PUSH=1
DOCKER_HUB_USERNAME=your_dockerhub_username
DOCKER_HUB_TOKEN=your_dockerhub_access_token

# Optional overrides (uncomment to use)
# BUILD_PLATFORM=linux/amd64,linux/arm64
# NO_CACHE=1
